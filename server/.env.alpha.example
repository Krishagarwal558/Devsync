DEVSYNC_APP_NAME=DevSync Cloud Alpha
DEVSYNC_ENVIRONMENT=development
DEVSYNC_LOG_LEVEL=INFO
DEVSYNC_DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DB?ssl=require
DEVSYNC_JWT_SECRET_KEY=replace-with-a-random-secret-at-least-32-characters-long
DEVSYNC_JWT_ALGORITHM=HS256
DEVSYNC_ACCESS_TOKEN_MINUTES=15
DEVSYNC_REFRESH_TOKEN_DAYS=30
DEVSYNC_BCRYPT_ROUNDS=12
DEVSYNC_STORAGE_ROOT=/app/server/storage
DEVSYNC_MAX_UPLOAD_BYTES=52428800
DEVSYNC_CORS_ALLOWED_ORIGINS=["http://127.0.0.1:8000","http://localhost:8000"]
DEVSYNC_RATE_LIMIT_REQUESTS=120
DEVSYNC_RATE_LIMIT_WINDOW_SECONDS=60
