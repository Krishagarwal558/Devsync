DEVSYNC_APP_NAME=DevSync Cloud
DEVSYNC_APP_VERSION=0.2.0b1
DEVSYNC_ENVIRONMENT=production
DEVSYNC_LOG_LEVEL=INFO
DEVSYNC_HOST=0.0.0.0
DEVSYNC_PORT=8000
DEVSYNC_RELOAD=false
DEVSYNC_DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME?ssl=require
DEVSYNC_JWT_SECRET_KEY=replace-with-a-random-secret-at-least-32-characters-long
DEVSYNC_JWT_ALGORITHM=HS256
DEVSYNC_ACCESS_TOKEN_MINUTES=15
DEVSYNC_REFRESH_TOKEN_DAYS=30
DEVSYNC_BCRYPT_ROUNDS=12
DEVSYNC_STORAGE_ROOT=/var/lib/devsync/storage
DEVSYNC_MAX_UPLOAD_BYTES=52428800
DEVSYNC_CORS_ALLOWED_ORIGINS=["https://your-devsync-backend.onrender.com"]
DEVSYNC_RATE_LIMIT_REQUESTS=120
DEVSYNC_RATE_LIMIT_WINDOW_SECONDS=60
